@layout AppLayout
@page "/ja-procesos-siges"
@attribute [Authorize(Roles = AppRoles.JefeArea)]
@using Microsoft.AspNetCore.Authorization
@using WEB.Components.Shared
@using WEB.Core.Mediator
@using WEB.Core.Services
@using WEB.Data
@using WEB.Core.Interfaces
@using WEB.Services
@rendermode InteractiveServer
@inject IMediator Mediator
@inject ICurrentUser CurrentUser
@inject ExcelExportService ExcelExportService
@inject ExportPdfService ExportPdf
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager


<FluentLayout>
    <FluentGrid Spacing="4" Style="width: 100%;">
      
        <FluentGridItem xs="12">
            <FluentGrid Justify="JustifyContent.SpaceBetween" AlignItems="Alignment.Center" Spacing="2">
                <FluentGridItem xs="12" md="6">
                    <Title ValueTitle="SIGES Área" Icono="@(new Icons.Filled.Size24.Flowchart())" />
                </FluentGridItem>
                <FluentGridItem xs="12" md="6" Justify="JustifyContent.FlexEnd">
                    <FluentStack HorizontalAlignment="HorizontalAlignment.End" Orientation="Orientation.Horizontal" HorizontalGap="8" Wrap="true" Style="margin-top: 8px;">
                        <FluentMenuButton IconStart="@(new Icons.Regular.Size20.ArrowDownload())" Text="Exportar">
                            <FluentMenuItem Disabled="@(!procesos.Any())" OnClick="@ExportToExcel">Excel</FluentMenuItem>
                            <FluentMenuItem Disabled="@(!procesos.Any())" OnClick="@ExportToPdf">PDF</FluentMenuItem>
                        </FluentMenuButton>
                        <FluentButton Appearance="Appearance.Accent"
                                      OnClick="@(() => NavigationManager.NavigateTo("/indicador-de-area"))"
                                      IconStart="@(new Icons.Regular.Size20.ArrowLeft())">
                            Volver
                        </FluentButton>
                    </FluentStack>
                </FluentGridItem>
            </FluentGrid>
        </FluentGridItem>
        
        <FluentGridItem xs="12">
            @if (isLoading)
            {
                <FluentStack HorizontalAlignment="HorizontalAlignment.Center" Style="padding: 60px;">
                    <FluentProgressRing />
                </FluentStack>
            }
            else if (areaId == null)
            {
                <FluentLabel>No tiene un área asignada.</FluentLabel>
            }
            else if (!procesos.Any())
            {
                <FluentStack HorizontalAlignment="HorizontalAlignment.Center" Style="padding: 60px;">
                    <FluentLabel>No hay procesos registrados.</FluentLabel>
                </FluentStack>
            }
            else
            {
                <FluentTabs @bind-ActiveTabId="activeTabId" OnTabChange="HandleTabChange">
                    @foreach (var proceso in procesos)
                    {
                        var procesoId = proceso.Id;
                        var tabId = $"tab-{procesoId}";
                        <FluentTab Id="@tabId" Label="@proceso.Nombre">
                                <JAProcesoSIGEsTable ProcesoId="procesoId" AreaId="areaId.Value" />
                        </FluentTab>
                    }
                </FluentTabs>
            }
        </FluentGridItem>
    </FluentGrid>
</FluentLayout>