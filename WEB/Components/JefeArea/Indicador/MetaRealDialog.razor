@using WEB.Core.Mediator
@using WEB.Interfaces
@inject IMediator Mediator
@inject IUnitOfWorkAccessor UnitOfWorkAccessor

<FluentDialogBody>
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
        @if (_isPorcentual)
        {
            <FluentNumberField @bind-Value="_valorTotal" Label="@_valorTotalLabel" />
            <FluentNumberField @bind-Value="_valorReal" Label="@_valorRealLabel" />
        }
        else
        {
            <FluentTextField @bind-Value="_metaReal" Label="Meta Real" />
        }
        @if (!string.IsNullOrEmpty(_error))
        {
            <FluentLabel Color="Color.Error">@_error</FluentLabel>
        }
    </FluentStack>
</FluentDialogBody>
<FluentDialogFooter>
    <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.Right">
        <FluentButton Appearance="Appearance.Stealth" OnClick="Cancel">Cancelar</FluentButton>
        <FluentButton Appearance="Appearance.Accent" OnClick="Save">Asignar</FluentButton>
    </FluentStack>
</FluentDialogFooter>