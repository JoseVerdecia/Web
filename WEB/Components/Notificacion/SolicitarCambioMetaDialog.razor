@using System.Security.Claims
@using WEB.Core.Helpers
@using WEB.Core.Mediator
@using WEB.Features.Notificacion.Crear
@using WEB.Interfaces
@inject INotificationService NotificationService  

<FluentDialog Open="@Visible" 
              Modal="true"
              TrapFocus="true"
              Blocking="@_isSubmitting">
    <FluentDialogHeader>
        <FluentStack Horizontal Gap="8" VerticalAlignment="VerticalAlignment.Center">
            <FluentIcon Value="@(new Icons.Filled.Size20.ArrowSplit())" Size="20" />
            <span>Solicitar cambio de meta</span>
        </FluentStack>
    </FluentDialogHeader>
    <FluentDialogBody>
        <FluentStack VerticalGap="16" Style="width: 400px;">
            <FluentCard Style="background: var(--neutral-fill-stealth);">
                <FluentStack Vertical Gap="4" Style="padding: 12px;">
                    <FluentTextField>@IndicadorNombre</FluentTextField>
                    <FluentTextField>@AreaNombre</FluentTextField>
                    <FluentStack HorizontalGap="8" Style="margin-top: 8px;">
                        <FluentTextField>Meta actual:</FluentTextField>
                        <FluentBadge Appearance="Appearance.Filled">@MetaActual</FluentBadge>
                    </FluentStack>
                </FluentStack>
            </FluentCard>
            <FluentTextField @bind-Value="_nuevaMeta"
                             Label="Nueva meta propuesta"
                             Required="true"
                             ValidationMessage="@_metaError"
                             Placeholder="@PlaceholderMeta"
                             Pattern="@PatternMeta" />
          
            <FluentTextArea Label="Motivo del cambio" @bind-Value="_mensaje" Rows="3" Placeholder="Explique por qué solicita este cambio..." />
            
        </FluentStack>
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Filled" OnClick="Close" Disabled="@_isSubmitting">Cancelar</FluentButton>
        <FluentButton Appearance="Appearance.Accent" OnClick="SubmitAsync" Disabled="@_isSubmitting">
            @if (_isSubmitting)
            {
                <FluentProgressRing Size="16" Style="margin-right: 8px;" />
            }
            Enviar solicitud
        </FluentButton>
    </FluentDialogFooter>
</FluentDialog>

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    [Parameter] public int IndicadorDeAreaId { get; set; }
    [Parameter] public string IndicadorNombre { get; set; } = "";
    [Parameter] public string AreaNombre { get; set; } = "";
    [Parameter] public string MetaActual { get; set; } = "";
    [Parameter] public EventCallback OnSuccess { get; set; }

    [Inject] private IMediator Mediator { get; set; } = null!;
    [Inject] private AuthenticationStateProvider AuthStateProvider { get; set; } = null!;
    // [Inject] private INotificationService NotificationService { get; set; } = null!;  (si se prefiere en code-behind)

    private string _nuevaMeta = "";
    private string _mensaje = "";
    private string _metaError = "";
    private bool _isSubmitting;

    private bool MetaEsPorcentual => MetaActual?.Trim().EndsWith("%") ?? false;
    private string PatternMeta => MetaEsPorcentual ? @"^\d+(\.\d+)?%$" : @"^\d+(\.\d+)?$";
    private string PlaceholderMeta => MetaEsPorcentual ? "Ej: 95% o 95.5%" : "Ej: 95 o 95.5";

    private async Task Close()
    {
        ResetForm();
        await VisibleChanged.InvokeAsync(false);
    }

    private void ResetForm()
    {
        _nuevaMeta = "";
        _mensaje = "";
        _metaError = "";
        _isSubmitting = false;
    }

    private async Task SubmitAsync()
    {
        _metaError = "";
        _isSubmitting = true;

        if (string.IsNullOrWhiteSpace(_nuevaMeta))
        {
            _metaError = "La nueva meta es requerida";
            NotificationService.ShowError(_metaError);  
            _isSubmitting = false;
            return;
        }

        if (!MetaHelper.TryParsearMeta(_nuevaMeta, out _, out bool isPorcentaje))
        {
            _metaError = "El formato de la meta no es válido";
            NotificationService.ShowError(_metaError);   // 👈 Toast añadido
            _isSubmitting = false;
            return;
        }

        if (MetaEsPorcentual != isPorcentaje)
        {
            _metaError = MetaEsPorcentual
                ? "Debe ingresar un valor con % (ej: 95%)"
                : "Debe ingresar un valor sin % (ej: 95)";
            NotificationService.ShowError(_metaError);  
            _isSubmitting = false;
            return;
        }

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? string.Empty;

        var request = new CrearSolicitudCambioMetaRequest(IndicadorDeAreaId, _nuevaMeta, _mensaje, userId);
        var result = await Mediator.Send(request);

        if (result.IsFailure)
        {
            _isSubmitting = false;
            return;
        }

        await Close();
        await OnSuccess.InvokeAsync();
    }
}