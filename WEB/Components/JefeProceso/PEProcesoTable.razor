@using Microsoft.AspNetCore.Authorization
@using WEB.Core.Mediator
@using WEB.Data
@using WEB.Enums
@attribute [Authorize(Roles = AppRoles.JefeProceso)]
@inject IMediator Mediator

@if (isLoading)
{
    <FluentProgressRing />
}
else if (!indicadores.Any())
{
    <FluentStack HorizontalAlignment="HorizontalAlignment.Center" Style="padding: 40px;">
        <FluentIcon Value="@(new Icons.Regular.Size24.DismissCircle())" Style="margin-bottom: 8px; opacity: 0.4;" />
        <FluentLabel Typo="Typography.Subject">Este proceso no tiene indicadores registrados.</FluentLabel>
    </FluentStack>
}
else
{
    <table class="pe-table">
        <thead>
        <tr>
            <th>OE</th>
            <th>INDICADOR</th>
            <th>@DateTime.Now.Year</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var ind in indicadores.OrderBy(i => i.Id))
        {
            var esEscencial = ind.Tipo == IndicadorTipo.Escencial;
            <tr>
                <td class="celda-oe">
                    @if (ind.Objetivos.Any())
                    {
                        @string.Join("/", ind.Objetivos.OrderBy(o => o.NumeroObjetivo).Select(o => o.NumeroObjetivo))
                    }
                    else
                    {
                        <span class="sin-oe">—</span>
                    }
                </td>
                <td class="@(esEscencial ? "fila-escencial" : "")">
                    @ind.Nombre
                </td>
                <td class="celda-meta">@ind.MetaCumplir</td>
            </tr>
        }
        </tbody>
    </table>
}