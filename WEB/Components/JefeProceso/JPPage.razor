@layout AppLayout
@page "/indicadores/jefeProceso"
@attribute [Authorize(Roles=AppRoles.JefeProceso)]
@using Microsoft.AspNetCore.Authorization
@using WEB.Components.Administrador.Indicador
@using WEB.Core.Mediator
@using WEB.Core.Interfaces
@using WEB.Data
@using WEB.Components.Shared
@inject IDialogService DialogService
@inject IMediator Mediator
@inject NavigationManager NavigationManager
@inject ICurrentUser CurrentUser
@rendermode InteractiveServer


<FluentLayout>
    <FluentGrid Spacing="2" Justify="JustifyContent.SpaceBetween" Style="width: 100%;">
        <FluentGridItem xs="12" md="6" Style="padding-bottom: 8px;">
    
            <Title Icono="@(new Icons.Regular.Size20.ChartMultiple())" ValueTitle="@procesoNombre"></Title>
        </FluentGridItem>
        <FluentGridItem xs="12" md="6" Justify="JustifyContent.FlexEnd">
            <FluentStack Orientation="Orientation.Horizontal"
                         Wrap="true"
                         HorizontalGap="8"
                         VerticalGap="8"
                         HorizontalAlignment="HorizontalAlignment.End">
                <FluentButton Appearance="Appearance.Accent"
                              OnClick="@(() => NavigationManager.NavigateTo("/indicadores/jefeProceso/tabla-proceso"))"
                              IconStart="@(new Icons.Regular.Size20.Table())">
                    PE
                </FluentButton>
            
                <FluentButton Appearance="Appearance.Accent"
                              OnClick="@(() => NavigationManager.NavigateTo("/jp-objetivos-siges"))"
                              IconStart="@(new Icons.Regular.Size20.Flag())">
                    Objetivos
                </FluentButton>
            
                <FluentButton 
                    Appearance="Appearance.Accent"
                    OnClick="@(() => NavigationManager.NavigateTo("/jefe-proceso/evaluacion"))">Evaluacion</FluentButton>
                
                <FluentButton Appearance="Appearance.Accent"
                              OnClick="@(() => NavigationManager.NavigateTo("/indicadores/jefeProceso/siges"))"
                              IconStart="@(new Icons.Regular.Size20.Document())">
                    SIGES
                </FluentButton>
                
                <FluentButton Appearance="Appearance.Accent"
                              OnClick="@(() => NavigationManager.NavigateTo("/indicadores/jefeProceso/form"))">
                    Crear
                </FluentButton>
            </FluentStack>
        </FluentGridItem>
    </FluentGrid>
    
    <FluentDivider Style="margin: 1rem 0;"/>

    <FluentTabs Width="100%" @bind-ActiveTabId="@ActiveTabId" OnTabChange="HandleTabChange">
        <FluentTab Id="tab-activos" Label="Indicadores activos">
            @if (isLoadingActivos)
            {
                <FluentStack HorizontalAlignment="HorizontalAlignment.Center" Style="padding: 40px;">
                    <FluentProgressRing/>
                </FluentStack>
            }
            else
            {
               
                <div class="grid-scroll-container">
                    <FluentSplitter Orientation="Orientation.Horizontal"
                                    Panel1Size="60%"
                                    Panel2Size="40%"
                                    Panel1MinSize="400px"
                                    Panel2MinSize="250px"
                                    Collapsed="@(selectedIndicador == null)"
                                    BarSize="4">
                        <Panel1>
                            <div style="height: 100%; display: flex; flex-direction: column; overflow: auto; min-height: 0;">
                                <IndicadorDataGrid Items="gridItems"
                                                   AreasBaseUrl="/indicadores/jefeProceso"
                                                   EditBaseUrl="/indicadores/jefeProceso/form"
                                                   OnDelete="DeleteIndicador"
                                                   OnViewDetails="ViewIndicadorDetails"
                                                   OnRowSelected="HandleRowSelected"/>
                            </div>
                        </Panel1>
                        <Panel2>
                            <div style="height: 100%; display: flex; flex-direction: column; background: var(--neutral-layer-1);">
                                @if (selectedIndicador != null)
                                {
                                    <header style="display: flex; justify-content: space-between; align-items: center; padding: 12px 16px; border-bottom: 1px solid var(--neutral-stroke); flex-shrink: 0;">
                                        <FluentLabel Style="font-weight: 600;">Áreas del indicador</FluentLabel>
                                        <FluentButton Appearance="Appearance.Stealth"
                                                      IconStart="@(new Icons.Regular.Size16.Dismiss())"
                                                      OnClick="() => selectedIndicador = null"
                                                      Title="Cerrar panel"/>
                                    </header>
                                    <div style="flex: 1; overflow: auto; padding: 16px;">
                                        <IndicadorDeAreaDetailGrid Areas="selectedIndicador.Areas"/>
                                    </div>
                                }
                                else
                                {
                                    <div style="display: flex; align-items: center; justify-content: center; height: 100%; color: var(--neutral-foreground-hint);">
                                        <FluentLabel>Seleccione un indicador para ver sus áreas</FluentLabel>
                                    </div>
                                }
                            </div>
                        </Panel2>
                    </FluentSplitter>
                </div>
            }
        </FluentTab>

        <FluentTab Id="tab-papelera" Label="Papelera">
            @if (isLoadingPapelera)
            {
                <FluentStack HorizontalAlignment="HorizontalAlignment.Center" Style="padding: 40px;">
                    <FluentProgressRing/>
                </FluentStack>
            }
            else
            {
                <IndicadorDeletedDataGrid @ref="deletedDataGrid"
                                          Items="deletedGridItems"
                                          OnRestore="RestoreSingleIndicador"
                                          OnDeletePermanently="DeletePermanently"/>
            }
        </FluentTab>
    </FluentTabs>
</FluentLayout>

<style>
    @@media (max-width: 959px) {
        .grid-scroll-container {
            overflow-x: auto;
        }
    }
</style>