@layout AppLayout
@page "/evaluar/indicador-de-area/{Id:int}"
@attribute [Authorize(Roles = AppRoles.JefeProceso)]
@using Microsoft.AspNetCore.Authorization
@using WEB.Core.Extensions
@using WEB.Core.Mediator
@using WEB.Core.Services
@using WEB.Data
@using WEB.Interfaces
@rendermode InteractiveServer
@inject IMediator Mediator
@inject ICurrentUser CurrentUser
@inject NavigationManager NavigationManager



<FluentLayout>
    <FluentGrid Spacing="4">
        <FluentGridItem Justify="JustifyContent.FlexEnd" xs="12">
            <FluentButton Appearance="Appearance.Accent"
                          IconStart="@(new Icons.Regular.Size20.ArrowLeft())"
                          OnClick="Regresar">
                Volver
            </FluentButton>
        </FluentGridItem>

        <FluentGridItem xs="12">
            @if (isLoading)
            {
                <FluentStack HorizontalAlignment="HorizontalAlignment.Center" Style="margin-top: 40px;">
                    <FluentProgressRing />
                </FluentStack>
            }
            else if (area == null)
            {
                <FluentMessageBar Intent="MessageIntent.Error" AllowDismiss="true">
                    No se encontró el indicador de área.
                </FluentMessageBar>
            }
            else
            {
                <FluentCard Style="padding-left: 20px;">
                    <FluentStack Orientation="Orientation.Horizontal">
                        <FluentStack Orientation="Orientation.Vertical" VerticalGap="20">
                            <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                                <FluentLabel Typo="Typography.H4" Style="margin-bottom: 0;">@area.NombreIndicadorPadre</FluentLabel>
                                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="10" VerticalAlignment="VerticalAlignment.Center">
                                    <FluentLabel Typo="Typography.Body" Style="color: var(--neutral-foreground-hint);">Área: @area.AreaNombre</FluentLabel>
                                    <FluentBadge Appearance="Appearance.Accent" Color="@area.EvaluacionColor" Style="font-size: 0.9em; padding: 4px 12px;">
                                        @area.Evaluacion.GetDisplayName()
                                    </FluentBadge>
                                </FluentStack>
                                @if (area.IsMetaCumplirPorcentual)
                                {
                                    <FluentCard Height="fit-content">
                                        <FluentStack Orientation="Orientation.Vertical">
                                            <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold" Color="Color.Accent">Valor Total</FluentLabel>
                                            <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">@*@area.ValorTotalLabel*@ Valor Total</FluentLabel>
                                        </FluentStack>
                                    </FluentCard>
                               
                                    <FluentCard Height="fit-content">
                                        <FluentStack Orientation="Orientation.Vertical">
                                            <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold" Color="Color.Accent">Valor Real</FluentLabel>
                                            <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">@*@area.ValorRealLabel*@ Valor Real</FluentLabel>
                                        </FluentStack>
                                    </FluentCard>
                                }
                             
                               
                            </FluentStack>

                           
                                
                         
                            <FluentGrid Style="padding: 24px;" Spacing="4">
                                <FluentStack Orientation="Orientation.Horizontal">
                                    <FluentCard>
                                        <FluentStack HorizontalAlignment="HorizontalAlignment.SpaceBetween" Style="margin-bottom: 20px;" HorizontalGap="120" Orientation="Orientation.Horizontal">
                                            <FluentGridItem xs="6" sm="6">
                                                <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                                                    <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold" Color="Color.Accent">Meta</FluentLabel>
                                                    <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">@area.MetaCumplir</FluentLabel>
                                                </FluentStack>
                                            </FluentGridItem>
                                            <FluentGridItem xs="6" sm="6">
                                                <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                                                    <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold" Color="Color.Accent">Real </FluentLabel>
                                                    <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">@area.MetaReal</FluentLabel>
                                                </FluentStack>
                                            </FluentGridItem>
                                        </FluentStack>


                                        @if (area.IsMetaCumplirPorcentual)
                                        {
                                            <FluentStack HorizontalGap="120" Orientation="Orientation.Horizontal">
                                                <FluentGridItem xs="6" sm="6">
                                                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                                                        <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold" Color="Color.Accent">Total</FluentLabel>
                                                        <FluentLabel Typo="Typography.Subject">@area.ValorTotal.FormatearDecimal()</FluentLabel>
                                                    </FluentStack>
                                                </FluentGridItem>
                                                <FluentGridItem xs="6" sm="6">
                                                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                                                        <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold" Color="Color.Accent">Real</FluentLabel>
                                                        <FluentLabel Typo="Typography.Subject">@area.ValorReal.FormatearDecimal()</FluentLabel>
                                                    </FluentStack>
                                                </FluentGridItem>
                                            </FluentStack>

                                        }
                                    </FluentCard>
                                    
                                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
                                        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="12" Wrap="true">
                                            <FluentSelect Items="@evaluaciones"
                                                          @bind-Value="@evaluacionSeleccionada"
                                                          OptionValue="e => e.Value"
                                                          OptionText="e => e.Text"
                                                          Style="min-width: 220px;"/>
                                            <FluentButton Appearance="Appearance.Accent"
                                                          OnClick="GuardarCambios"
                                                          Disabled="@(evaluacionSeleccionada == area.Evaluacion.ToString())">
                                                Cambiar
                                            </FluentButton>
                                        </FluentStack>
                                    </FluentStack>
                                </FluentStack>
                            </FluentGrid>
                            
                            @if (!string.IsNullOrEmpty(mensaje))
                            {
                                <FluentMessageBar Intent="MessageIntent.Success" AllowDismiss="true" Style="margin-top: 8px;">@mensaje</FluentMessageBar>
                            }
                            @if (!string.IsNullOrEmpty(error))
                            {
                                <FluentMessageBar Intent="MessageIntent.Error" AllowDismiss="true" Style="margin-top: 8px;">@error</FluentMessageBar>
                            }
                        </FluentStack>
                        
                        <FluentDivider Role="DividerRole.Separator" Orientation="Orientation.Vertical"/>
                        <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                                <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">Valoración cualitativa del área</FluentLabel>
                                @if (string.IsNullOrWhiteSpace(area.ValorCualitativo))
                                {
                                    <FluentLabel Style="color: var(--neutral-foreground-hint); font-style: italic;">Sin valoración cualitativa registrada.</FluentLabel>
                                }
                                else
                                {
                                    <FluentCard Style="padding: 16px; background: var(--neutral-layer-2); border-radius: 6px;">
                                        <FluentLabel Style="white-space: pre-wrap; line-height: 1.5;">@area.ValorCualitativo</FluentLabel>
                                    </FluentCard>
                                }
                            </FluentStack>
                      
                    </FluentStack>
                    
                </FluentCard>
            }
        </FluentGridItem>
    </FluentGrid>
</FluentLayout>