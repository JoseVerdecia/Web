@page "/indicadores/jefeProceso/siges"
@layout AppLayout
@attribute [Authorize(Roles = AppRoles.JefeProceso)]
@using Microsoft.AspNetCore.Authorization
@using WEB.Components.Shared
@using WEB.Core.Mediator
@using WEB.Data
@using WEB.Features.Proceso.Get
@using WEB.Core.Interfaces
@using WEB.Services
@inject IMediator Mediator
@inject ICurrentUser CurrentUser
@inject ExcelExportService ExcelExportService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@rendermode InteractiveServer


<FluentLayout>
   
    <FluentGrid Spacing="2" Justify="JustifyContent.SpaceBetween" Style="width: 100%;">
        <FluentGridItem xs="12" md="6" Style="padding-bottom: 8px;">
            <Title Icono="@(new Icons.Regular.Size20.ChartMultiple())" ValueTitle="@procesoNombre" />
        </FluentGridItem>
        <FluentGridItem xs="12" md="6" Justify="JustifyContent.FlexEnd">
            <FluentStack Orientation="Orientation.Horizontal"
                         Wrap="true"
                         HorizontalGap="8"
                         VerticalGap="8"
                         HorizontalAlignment="HorizontalAlignment.End">
                <FluentMenuButton IconStart="@(new Icons.Regular.Size20.ArrowDownload())" Text="Exportar">
                    <FluentMenuItem OnClick="@ExportToExcel">Excel</FluentMenuItem>
                    <FluentMenuItem OnClick="@ExportToPdf">PDF</FluentMenuItem>
                </FluentMenuButton>
                <FluentButton Appearance="Appearance.Accent"
                              OnClick="@(() => NavigationManager.NavigateTo("/indicadores/jefeProceso"))"
                              IconStart="@(new Icons.Regular.Size20.ArrowLeft())">
                    Volver
                </FluentButton>
            </FluentStack>
        </FluentGridItem>
    </FluentGrid>

    <FluentDivider Style="margin: 1rem 0;" />

    @if (isLoadingProceso)
    {
        <FluentStack HorizontalAlignment="HorizontalAlignment.Center" Style="padding: 60px;">
            <FluentProgressRing />
        </FluentStack>
    }
    else if (procesoId == null)
    {
        <FluentStack HorizontalAlignment="HorizontalAlignment.Center" Style="padding: 60px;">
            <FluentLabel Typo="Typography.Subject">No se encontró su proceso asociado.</FluentLabel>
        </FluentStack>
    }
    else
    {
        <div class="table-scroll-container">
            <ProcesoSIGEsTable ProcesoId="procesoId.Value" />
        </div>
    }
</FluentLayout>

<style>
    @@media (max-width: 959px) {
        .table-scroll-container {
            overflow-x: auto;
        }
    }
</style>

@code {
    private int? procesoId;
    private string procesoNombre = "Cargando...";
    private bool isLoadingProceso = true;

    protected override async Task OnInitializedAsync()
    {
        var user = await CurrentUser.GetUserAsync();
        if (user == null)
        {
            isLoadingProceso = false;
            return;
        }

        var result = await Mediator.Send(new GetProcesoByJefeIdRequest(user.Id));
        if (result.IsSuccess && result.Value is not null)
        {
            procesoId = result.Value.Id;
            procesoNombre = result.Value.Nombre;
        }
        isLoadingProceso = false;
    }

    private async Task ExportToExcel()
    {
        if (procesoId == null) return;
        var data = await ExcelExportService.ExportProcesoToExcelSIEGEAsync(procesoId.Value);
        await JSRuntime.InvokeVoidAsync("downloadFile", $"Proceso_{procesoId}.xlsx", Convert.ToBase64String(data));
    }

    private async Task ExportToPdf()
    {
        if (procesoId == null) return;
        var data = await ExcelExportService.ExportProcesoToPdfSIEGEAsync(procesoId.Value);
        await JSRuntime.InvokeVoidAsync("downloadFile", $"Proceso_{procesoId}.pdf", Convert.ToBase64String(data));
    }
}