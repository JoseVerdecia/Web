@using WEB.Features.Objetivo.Dto
@implements IDialogContentComponent<WEB.Features.Objetivo.Dto.ObjetivoDto>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="10">
    <FluentLabel><b>ID:</b> @Content.Id</FluentLabel>
    <FluentLabel><b>Nombre:</b> @Content.Nombre</FluentLabel>
    <FluentLabel><b>Evaluacion:</b> @Content.Evaluacion</FluentLabel>
    
    <FluentStack HorizontalAlignment="HorizontalAlignment.End" Style="margin-top:20px;">
        <FluentButton Appearance="Appearance.Accent" OnClick="Close" Autofocus="true">Cerrar</FluentButton>
    </FluentStack>
</FluentStack>

@code {
    [CascadingParameter] public FluentDialog Dialog { get; set; } = default!;
    [Parameter]public ObjetivoDto Content { get; set; }
    
    private async Task Close()
    {
        await Dialog.CloseAsync();
    }
}