@using WEB.Common
@using WEB.Components.Shared
@using WEB.Core.Extensions
@using WEB.Enums
@inject NavigationManager NavigationManager


<FluentStack Orientation="Orientation.Horizontal" Gap="10" Wrap="true" Style="margin-bottom: 12px; align-items: center;">
    <FluentSearch @bind-Value="nameFilter"
                  @bind-Value:after="ResetPagination"
                  Immediate="true"
                  Placeholder="Buscar nombre..."
                  Style="min-width: 200px; max-width: 300px; flex-grow: 1;" />

    <FluentSelect Items="evaluacionOptions"
                  @bind-Value="evaluacionFilter"
                  @bind-Value:after="ResetPagination"
                  OptionValue="opt => opt.Value"
                  OptionText="opt => opt.Text"
                  Placeholder="Evaluación"
                  Style="min-width: 150px;" />

    <FluentSelect Items="origenOptions"
                  @bind-Value="origenFilter"
                  @bind-Value:after="ResetPagination"
                  OptionValue="opt => opt.Value"
                  OptionText="opt => opt.Text"
                  Placeholder="Origen"
                  Style="min-width: 150px;" />

    <FluentSelect Items="tipoOptions"
                  @bind-Value="tipoFilter"
                  @bind-Value:after="ResetPagination"
                  OptionValue="opt => opt.Value"
                  OptionText="opt => opt.Text"
                  Placeholder="Tipo"
                  Style="min-width: 150px;" />

    <FluentSelect Items="procesoOptions"
                  @bind-Value="procesoFilter"
                  @bind-Value:after="ResetPagination"
                  OptionValue="opt => opt.Value"
                  OptionText="opt => opt.Text"
                  Placeholder="Proceso"
                  Style="min-width: 180px;" />
    
    <FluentButton Appearance="Appearance.Outline"
                  IconStart="@(new Icons.Regular.Size20.ArrowReset())"
                  OnClick="ClearAllFilters"
                  Title="Limpiar todos los filtros">
        Limpiar
    </FluentButton>
</FluentStack>


<FluentDataGrid Items="@FilteredItems.AsQueryable()"
                Pagination="@paginationState"
                GenerateHeader="GenerateHeaderOption.Sticky"
                DisplayMode="DataGridDisplayMode.Table"
                GridTemplateColumns="0.5fr 2fr 0.3fr 0.3fr 1fr 0.3fr 0.3fr 1fr 1fr 0.5fr"
                MultiLine="true"
                ShowHover="true"
                RowClass="@GetRowClass"
                OnRowDoubleClick="(FluentDataGridRow<IndicadorDisplayItem> row) => HandleRowClick(row)"
                Style="width: 100%; overflow: visible !important;">
    <ChildContent>
        <SelectColumn TGridItem="IndicadorDisplayItem"
                      SelectMode="DataGridSelectMode.Multiple"
                      SelectFromEntireRow="false"
                      Property="@(e => e.IsSelected)"
                      OnSelect="@(async e => await OnItemSelect(e.Item, e.Selected))"
                      SelectAll="@Items.All(i => i.IsSelected)"
                      SelectAllChanged="@(async all => await OnSelectAllChanged(all))" />

        <TemplateColumn Title="Nombre" Align="Align.Start">
            <ChildContent>
                @{ var tooltipId = $"obs-{context.Id}"; }
                @if (!string.IsNullOrWhiteSpace(context.Observacion))
                {
                <FluentTooltip Anchor="@tooltipId" MaxWidth="300px" Delay="200" Position="TooltipPosition.Top">
                    <div style="white-space: pre-wrap; font-size: 12px;">@context.Observacion</div>
                </FluentTooltip>
                }

                @if (context.IsEscencial)
                {
                <span class="parent-name" id="@tooltipId">@context.Nombre</span>
                }
                else
                {
                <span class="parent-name-normal" id="@tooltipId">@context.Nombre</span>
                }
            </ChildContent>
        </TemplateColumn>

        <PropertyColumn HeaderTooltip="Meta a cumplir para el indicador"
                        Property="@(i => i.MetaCumplir)"
                        Align="Align.Center"
                        Title="Meta"/>

        <TemplateColumn HeaderTooltip="Meta real del indicador" Title="Real" Align="Align.Center">
            @(context.MetaReal ?? "—")
        </TemplateColumn>

        <TemplateColumn Title="Evaluación" Align="Align.Center">
            <ChildContent>
                <span style="color: @context.Evaluacion.GetBadgeColor(); font-weight: bold;">
                    @context.Evaluacion.GetDisplayName()
                </span>
            </ChildContent>
        </TemplateColumn>

        <TemplateColumn Title="Origen" HeaderTooltip="Origen del Indicador (MES/INTERNO)" Align="Align.Center">
            <ChildContent>
                @if (context.Origen == IndicadorOrigen.MES.GetDisplayName())
                {
                <FluentBadge Appearance="Appearance.Accent">@context.Origen</FluentBadge>
                }
                else
                {
                <FluentBadge Appearance="Appearance.Neutral">@context.Origen</FluentBadge>
                }
            </ChildContent>
        </TemplateColumn>

        <TemplateColumn Title="Tipo" HeaderTooltip="Tipo de Indicador (ESPECIAL/NECESARIO)" Align="Align.Center">
            <ChildContent>
                @if (context.IsEscencial)
                {
                <b>@context.Tipo</b>
                }
                else
                {
                @context.Tipo
                }
            </ChildContent>
        </TemplateColumn>

        <TemplateColumn Title="Proceso" HeaderTooltip="Proceso al que pertenece el indicador" Align="Align.Start">
            <ChildContent>
                @(context.ProcesoNombre ?? "Sin proceso")
            </ChildContent>
        </TemplateColumn>

        <TemplateColumn HeaderTooltip="Objetivos Estrategicos al que pertenece el indicador" Title="OE" Align="Align.Start">
            <ChildContent>
                <span class="objetivos-badge">@FormatObjetivos(context.ObjetivosFormatted)</span>
            </ChildContent>
        </TemplateColumn>

        <TemplateColumn Title="Acciones" Align="Align.Start">
            <ChildContent>
                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="5">
                    <FluentButton StopPropagation="true" Appearance="Appearance.Accent" IconStart="@(new Icons.Regular.Size16.Edit())" OnClick="@(() => NavigateToEdit(context.Id))" Title="Editar indicador"/>
                    <FluentButton StopPropagation="true" Appearance="Appearance.Lightweight"
                                  IconStart="@(new Icons.Regular.Size16.Grid())"
                                  OnClick="@(() => NavigateToAreas(context.Id))" Title="Ver áreas"/>
                    <FluentButton StopPropagation="true" Appearance="Appearance.Outline" IconStart="@(new Icons.Regular.Size16.Delete())" OnClick="() => OnDelete.InvokeAsync(context)" Title="Eliminar indicador"/>
                </FluentStack>
            </ChildContent>
        </TemplateColumn>
    </ChildContent>

    <EmptyContent>
        <EmptyDataGridContent Mensaje="No hay Indicadores"/>
    </EmptyContent>
</FluentDataGrid>

<div style="flex-shrink: 0; padding-top: 10px;">
    <FluentPaginator State="@paginationState"/>
</div>