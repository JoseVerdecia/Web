@using Microsoft.AspNetCore.Identity
@using WEB.Data

@inject SignInManager<ApplicationUser> SignInManager

<FluentNavMenu Collapse="false">
    <FluentNavLink Href="Account/Manage" Match="NavLinkMatch.All">Perfil</FluentNavLink>
    <FluentNavLink Href="Account/Manage/Email">Email</FluentNavLink>
    <FluentNavLink Href="Account/Manage/ChangePassword">Contraseña</FluentNavLink>
    @*@if (hasExternalLogins)
    {
        <FluentNavLink Href="Account/Manage/ExternalLogins">Sesiones externas</FluentNavLink>
    }*@
    @*<FluentNavLink Href="Account/Manage/TwoFactorAuthentication">Two-factor autenticacion</FluentNavLink>
    <FluentNavLink Href="Account/Manage/Passkeys">Claves de acceso</FluentNavLink>
    <FluentNavLink Href="Account/Manage/PersonalData">Datos personales</FluentNavLink>*@

</FluentNavMenu>


@code {
    private bool hasExternalLogins;

    protected override async Task OnInitializedAsync()
    {
        hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
    }

}