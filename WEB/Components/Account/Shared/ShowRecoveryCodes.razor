<StatusMessage Message="@StatusMessage"/>
<h3>Códigos de recuperación</h3>
<div class="alert alert-warning" role="alert">
    <p>
        <strong>Guarda estos códigos en un lugar seguro.</strong>
    </p>
    <p>
        Si pierdes tu dispositivo y no tienes los códigos de recuperación, perderás el acceso a tu cuenta.
    </p>
</div>
<FluentGrid>
    <FluentGridItem sm="12">
        @foreach (var recoveryCode in RecoveryCodes)
        {
            <div>
                <code class="recovery-code">@recoveryCode</code>
            </div>
        }

    </FluentGridItem>

</FluentGrid>


@code {
    [Parameter] public string[] RecoveryCodes { get; set; } = [];

    [Parameter] public string? StatusMessage { get; set; }
}