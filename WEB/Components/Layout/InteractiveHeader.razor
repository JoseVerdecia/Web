@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.SignalR.Client
@using WEB.Common
@using WEB.Components.Shared.Notificacion
@using WEB.Core.Extensions
@using WEB.Core.Mediator
@using WEB.Core.Services
@using WEB.Interfaces
@using WEB.Data
@using WEB.Enums
@using WEB.Features.Notificacion.GetByUser
@using WEB.Features.Notificacion.GetCount
@implements IDisposable
@inject ICurrentUser CurrentUser
@inject IDialogService DialogService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider
@inject NotificacionStateService NotificacionState
@inject UserManager<ApplicationUser> UserManager
@inject ProfilePictureService PictureService
@inject IndicadorUpdateStateService IndicadorUpdateState
@inject AdminPendingUsersState PendingState
@inject IMediator Mediator
@rendermode InteractiveServer


<FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="@VerticalAlignment.Center" HorizontalAlignment="HorizontalAlignment.End" Style="height: 48px; padding-inline-end: 10px; ">
    
    <AuthorizeView>
        <Authorized>
            <FluentInputFile @ref="_profilePictureUploader"
                             Mode="InputFileMode.SaveToTemporaryFolder"
                             Accept="image/*"
                             Multiple="false"
                             MaximumFileSize="@(5 * 1024 * 1024)"
                             OnCompleted="OnProfilePictureUploadedAsync"
                             DragDropZoneVisible="false"
                             Style="display: none;" />
            <FluentProfileMenu Status="@PresenceStatus.Available"
                               @bind-Open="isProfileMenuOpen"
                               HeaderLabel="Mi perfil"
                               Image="@appUser?.ProfilePictureUrl"
                               Initials="@appUser?.FullName.GetInitials()"
                               FullName="@appUser?.FullName"
                               EMail="@appUser?.Email"
                               TopCorner="true"
                               PopoverStyle="min-width: 280px;">
                <HeaderTemplate>
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="8">
                        <FluentButton Appearance="Appearance.Stealth"
                                      IconStart="@(new Icons.Regular.Size20.ImageEdit())"
                                      Title="Cambiar foto de perfil"
                                      OnClick="@(() => _profilePictureUploader?.ShowFilesDialogAsync())"/>
                    </FluentStack>
                </HeaderTemplate>
                <FooterTemplate>
                    <FluentStack Orientation="Orientation.Horizontal">
                        <FluentButton Appearance="Appearance.Stealth"
                                      Style="width: 100%; justify-content: flex-start;"
                                      IconStart="@(new Icons.Regular.Size20.PersonAccounts())"
                                      OnClick="GoToAccount">
                            <span style="margin-left: 8px;">Ver cuenta</span>
                        </FluentButton>

                        <form method="post" action="Account/Logout">
                            <AntiforgeryToken/>
                            <input type="hidden" name="ReturnUrl" value="@currentUrl"/>
                            <FluentButton Type="ButtonType.Submit"
                                          Appearance="Appearance.Stealth"
                                          IconStart="@(new Icons.Regular.Size20.SignOut())"
                                          Style="width: 100%; justify-content: flex-start;">
                                <span style="margin-left: 8px;">Cerrar sesión</span>
                            </FluentButton>
                        </form>
                    </FluentStack>

                </FooterTemplate>
            </FluentProfileMenu>

        </Authorized>
    </AuthorizeView>
    @if (CurrentUser.IsInRole(AppRoles.JefeArea) || CurrentUser.IsInRole(AppRoles.JefeProceso))
    {
        @if (_isInitialized)
        {
            <NotificacionBell />
        }
        else
        {
            <FluentProgressRing/>
        }
    }
</FluentStack>
@code {
    private string? currentUrl;
    private ApplicationUser? appUser;
    private bool isProfileMenuOpen = false;
    private HubConnection? _hubConnection;
    private bool _isInitialized = false;
    private FluentInputFile? _profilePictureUploader;

    private async Task OnProfilePictureUploadedAsync(IEnumerable<FluentInputFileEventArgs> files)
    {
        var fileList = files?.ToList();
        if (fileList == null || !fileList.Any() || fileList[0].LocalFile == null || appUser == null)
            return;

        var file = fileList[0];
        try
        {
            var newUrl = await PictureService.SaveFromLocalFileAsync(
                file.LocalFile.FullName,
                file.Name,
                appUser.Id);

            
            var freshUser = await UserManager.FindByIdAsync(appUser.Id);
            if (freshUser == null)
            {
                Console.WriteLine("Usuario no encontrado al intentar actualizar foto.");
                return;
            }

            freshUser.ProfilePictureUrl = newUrl;
            var result = await UserManager.UpdateAsync(freshUser);

            if (result.Succeeded)
            {
            
                appUser.ProfilePictureUrl = newUrl; 
                StateHasChanged();
                NavigationManager.Refresh(forceReload: true);
            }
            else
            {
               
                var errors = string.Join(", ", result.Errors.Select(e => e.Description));
                Console.WriteLine($"Error al actualizar foto: {errors}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Excepción en subida: {ex.Message}");
        }
    }
    protected override async Task OnInitializedAsync()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
        appUser = await CurrentUser.GetUserAsync();
        await SetupSignalRAsync();
        _isInitialized = true;
    }

    private async Task SetupSignalRAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        while (user.Identity?.IsAuthenticated != true)
        {
            await Task.Delay(200);
            authState = await AuthStateProvider.GetAuthenticationStateAsync();
            user = authState.User;
        }

        var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    
        if (string.IsNullOrEmpty(userId))
        {
            Console.WriteLine(" No se pudo obtener el userId para SignalR");
            return;
        }

        var hubUrl = NavigationManager.ToAbsoluteUri($"/hubs/notificaciones?userId={userId}");

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(hubUrl, options =>
            {
                options.HttpMessageHandlerFactory = (handler) =>
                {
                    if (handler is HttpClientHandler clientHandler)
                    {
                        clientHandler.ServerCertificateCustomValidationCallback =
                            HttpClientHandler.DangerousAcceptAnyServerCertificateValidator;
                    }
                    return handler;
                };
            })
            .WithAutomaticReconnect(new[]
            {
                TimeSpan.FromSeconds(0),
                TimeSpan.FromSeconds(2),
                TimeSpan.FromSeconds(5),
                TimeSpan.FromSeconds(10),
                TimeSpan.FromSeconds(30)
            })
            .Build();
        
        _hubConnection.On("RefreshPage", () =>
        {
            InvokeAsync(() =>
            {
                
                NavigationManager.Refresh(forceReload: true);
            });
        });
        
        _hubConnection.On("MetaActualizada", () =>
        {
            Console.WriteLine(" [SignalR] MetaActualizada recibida!");
            InvokeAsync(async () =>
            {
                Console.WriteLine(" Invocando IndicadorUpdateState.NotifyUpdate()");
                IndicadorUpdateState.NotifyUpdate();
                await LoadNotificationCountAsync();
                StateHasChanged();
            });
        });
        
        
        
        _hubConnection.On<NotificacionSignalRDto>("RecibirNotificacion", (notificacion) =>
        {
            Console.WriteLine($"RecibirNotificacion recibida. Id: {notificacion.Id}, Count: {notificacion.CountNoLeidas}");
            InvokeAsync(async () =>
            {
                NotificacionState.UpdateCount(notificacion.CountNoLeidas);
                await LoadNotificacionesAsync(); 
                StateHasChanged();
            });
        });
        
        _hubConnection.On("NotificacionLeida", (int count) =>
        {
            InvokeAsync(() =>
            {
                NotificacionState.UpdateCount(count);
                StateHasChanged();
            });
        });
        
        _hubConnection.On("NuevoUsuarioRegistrado", () =>
        {
            InvokeAsync(() =>
            {
                PendingState.SetCount(PendingState.PendingCount + 1);
                StateHasChanged();
            });
        });
        
        _hubConnection.On<dynamic>("SolicitudActualizada", (data) =>
        {
            InvokeAsync(() =>
            {
                int id = data.Id;
                string estado = data.Estado;
                int count = data.CountNoLeidas;

                var notif = NotificacionState.Notificaciones.FirstOrDefault(n => n.Id == id);
                if (notif != null)
                {
                    notif = notif with { Estado = Enum.Parse<EstadoNotificacion>(estado) };
                    NotificacionState.UpdateNotificacion(notif);
                }
                NotificacionState.UpdateCount(count);
                StateHasChanged();
            });
        });

      
        _hubConnection.On("TodasNotificacionesLeidas", () =>
        {
            InvokeAsync(() =>
            {
                NotificacionState.UpdateCount(0);
                StateHasChanged();
            });
        });
        
        _hubConnection.On<int>("NotificacionEliminada", (id) =>
        {
            InvokeAsync(() =>
            {
                NotificacionState.RemoveNotificacion(id);
            });
        });
  
        _hubConnection.Reconnected += async (connectionId) =>
        {
            var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrEmpty(userId))
            {
                // Aquí puedo llamar al handler de GetCount
            }
        };

        _hubConnection.Closed += async (error) =>
        {
            await Task.Delay(3000);
            try
            {
                await _hubConnection.StartAsync();
            }
            catch
            {
                // Log del error
            }
        };

        try
        {
            await _hubConnection.StartAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error conectando a SignalR: {ex.Message}");
        }
    }

    private async Task LoadNotificationCountAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrEmpty(userId)) return;

        var result = await Mediator.Send(new GetNotificacionCountRequest(userId));
        if (result.IsSuccess && result.Value != null)
        {
            NotificacionState.UpdateCount(result.Value.TotalNoLeidas);
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        InvokeAsync(StateHasChanged);
    }

    private void GoToAccount()
    {
        isProfileMenuOpen = false;
        NavigationManager.NavigateTo("Account/Manage");
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }

    private async Task LoadNotificacionesAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrEmpty(userId)) return;

        var result = await Mediator.Send(new GetNotificacionesByUsuarioRequest(userId));
        if (result.IsSuccess && result.Value != null)
        {
            NotificacionState.SetNotificaciones(result.Value);
        }
    }
    


}