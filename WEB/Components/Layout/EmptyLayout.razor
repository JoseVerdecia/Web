@inherits LayoutComponentBase

<FluentLayout>
    <FluentBodyContent>
        <div style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #222E58 0%, #92B921 100%); padding: 16px; box-sizing: border-box; overflow: hidden; z-index: 0;">
