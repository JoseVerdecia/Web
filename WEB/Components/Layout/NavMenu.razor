@rendermode InteractiveServer
@using WEB.Components.Shared
@using WEB.Core.Extensions
@using WEB.Core.Mediator
@using WEB.Core.Services
@using WEB.Interfaces
@using WEB.Features.Users.Get
@inject AdminPendingUsersState PendingState
@inject IMediator Mediator
@using WEB.Data
@inject ICurrentUser CurrentUser

<div class="navmenu">
    <input type="checkbox" title="Menu expand/collapse toggle" id="navmenu-toggle" class="navmenu-icon"/>
    <label for="navmenu-toggle" class="navmenu-icon">
        <FluentIcon Value="@(new Icons.Regular.Size20.Navigation())" Color="Color.Fill"/>
    </label>
    <nav class="sitenav" aria-labelledby="main-menu">
        <FluentNavMenu Id="main-menu" Collapsible="true" Width="250" Title="Navigation menu" @bind-Expanded="expanded" CustomToggle="true">
            
            <AuthorizeView>
                <Authorized>
                    @if (CurrentUser.IsInRole(AppRoles.Administrador))
                    {
                        
                        <FluentNavLink Href="/" Icon="@(new Icons.Regular.Size20.ChartMultiple())" Match="NavLinkMatch.All">Dashboard</FluentNavLink>
                        <FluentNavLink Href="/proceso" Icon="@(new Icons.Regular.Size20.Flowchart())" IconColor="Color.Accent">Proceso</FluentNavLink>
                        <FluentNavLink Href="/areas" Icon="@(new Icons.Regular.Size20.Location())">Áreas</FluentNavLink>
                        <FluentNavLink Href="/objetivos" Icon="@(new Icons.Regular.Size20.Flag())">Objetivos</FluentNavLink>
                        <FluentNavLink Href="/indicadores" Icon="@(new Icons.Regular.Size20.ArrowTrendingLines())">Indicadores</FluentNavLink>
                        <FluentCounterBadge Count="@PendingState.PendingCount"
                                            BackgroundColor="@Color.Error"
                                            Color="Color.Fill"
                                            HorizontalPosition="@(expanded ? 95 : 70)"
                                            VerticalPosition="60"
                                            ShowWhen="@(count => count > 0)">
                            <FluentNavLink Href="/admin/users"
                                           Icon="@(new Icons.Regular.Size20.People())">
                                Usuarios
                            </FluentNavLink>
                        </FluentCounterBadge>
                        <FluentNavLink Href="/evaluacion/programar" Icon="@(new Icons.Regular.Size20.ClipboardTask())">Evaluacion</FluentNavLink>
                    }
                    @if (CurrentUser.IsInRole(AppRoles.JefeProceso))
                    {
                        <FluentNavLink Href="/indicadores/jefeProceso" Icon="@(new Icons.Regular.Size20.ArrowTrendingLines())">Indicadores</FluentNavLink>
                    }
                    
                    @if (CurrentUser.IsInRole(AppRoles.JefeArea))
                    {
                        <FluentNavLink Href="/indicador-de-area" Icon="@(new Icons.Regular.Size20.ArrowTrendingLines())">Indicadores</FluentNavLink>
                    }
                   
                </Authorized>
                <NotAuthorized>
                    <FluentNavLink Href="Account/Login" Icon="@(new Icons.Regular.Size20.Accessibility())" IconColor="Color.Accent">Login</FluentNavLink>
                </NotAuthorized>
            </AuthorizeView>
        </FluentNavMenu>
    </nav>
</div>


@code {
    private bool expanded = false;
    private bool navGroupExpanded = true;
 
    protected override async Task OnInitializedAsync()
    {
        
        var result = await Mediator.Send(new GetPendingUsersCountRequest());
        if (result.IsSuccess)
            PendingState.SetCount(result.Value.Count);
        
        PendingState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        PendingState.OnChange -= StateHasChanged;
    }
    
}