@using WEB.Common
@using WEB.Core.Extensions
@using WEB.Enums
@using WEB.Features.IndicadorDeArea.Dto
@if (Areas == null || !Areas.Any())
{
    <FluentCard Style="padding: 20px; text-align: center;">
        <FluentLabel Style="color: var(--neutral-foreground-hint);">Este indicador no tiene áreas vinculadas.</FluentLabel>
    </FluentCard>
}
else
{
    <FluentDataGrid Items="@FilteredItems.AsQueryable()"
                    ResizableColumns="true"
                    DisplayMode="DataGridDisplayMode.Table"
                     ShowHover="true"
                    Pagination="@paginationState"
                    GridTemplateColumns="@(IndicadorEsPorcentual ? "1fr 0.5fr 0.5fr 0.5fr 0.5fr 1.5fr" : "1fr 0.5fr 0.5fr 1.5fr")"
                    MultiLine="true"
                    Style="width: 100%;">

        <ChildContent>
            <TemplateColumn Title="Área"
                            Align="Align.Start"
                            Filtered="@(!string.IsNullOrWhiteSpace(nameFilter))">
                <ColumnOptions>
                    <FluentSearch Autofocus="true"
                                  Immediate="true"
                                  @bind-Value="nameFilter"
                                  Placeholder="Buscar nombre..."
                                  Style="width: 100%;"/>
                </ColumnOptions>
                <ChildContent>
                    <FluentLabel>@context.AreaNombre</FluentLabel>
                </ChildContent>
            </TemplateColumn>
        
            <PropertyColumn Property="@(a => a.MetaCumplir)" Title="Meta" Align="Align.Center" />
            
            @if (IndicadorEsPorcentual)
            {
                <PropertyColumn Property="@(a => a.ValorTotal)" Title="Valor Total" Align="Align.Center" />
                <PropertyColumn Property="@(a => a.ValorReal)" Title="Valor Real" Align="Align.Center" />
            }
        
            <TemplateColumn Title="Real" Align="Align.Center">
                @(context.MetaReal ?? "—")
            </TemplateColumn>
            
            <TemplateColumn Title="Tipo"
                            Align="Align.Center"
                            Filtered="@(!string.IsNullOrWhiteSpace(tipoFilter))">
                <ColumnOptions>
                    <FluentSelect Items="@tipoOptions"
                                  Position="SelectPosition.Below"
                                  Value="@tipoFilter"
                                  ValueChanged="@(async v => { tipoFilter = v; await ResetPagination(); })"
                                  OptionValue="opt => opt.Value"
                                  OptionText="opt => opt.Text"
                                  Placeholder="Filtrar tipo"/>
                    <FluentButton Appearance="Appearance.Outline"
                                  IconStart="@(new Icons.Regular.Size20.ArrowReset())"
                                  OnClick="ClearTipoFilter"
                                  Title="Limpiar filtro"/>
                </ColumnOptions>
                <ChildContent>
                    <FluentBadge Appearance="@(context.Tipo == AreaTipo.Facultad ? Appearance.Accent : Appearance.Neutral)">
                        @context.Tipo.GetDisplayName()
                    </FluentBadge>
                </ChildContent>
            </TemplateColumn>
        
            <TemplateColumn Title="Evaluación"
                            Align="Align.Center"
                            Filtered="@(!string.IsNullOrWhiteSpace(evaluacionFilter))">
                <ColumnOptions>
                    <FluentSelect Items="evaluacionOptions"
                                  Position="SelectPosition.Below"
                                  Value="evaluacionFilter"
                                  ValueChanged="@(async v => { evaluacionFilter = v; await ResetPagination(); })"
                                  OptionValue="opt => opt.Value"
                                  OptionText="opt => opt.Text"
                                  Placeholder="Filtrar evaluación"/>
                    
                    <FluentButton Appearance="Appearance.Outline"
                                  IconStart="@(new Icons.Regular.Size20.ArrowReset())"
                                  OnClick="ClearEvaluacionFilter"
                                  Title="Limpiar filtro"/>
                </ColumnOptions>
                <ChildContent>
                    <span style="color: @context.Evaluacion.GetBadgeColor(); font-weight: bold;">
                        @context.Evaluacion.GetDisplayName()
                    </span>
                </ChildContent>
            </TemplateColumn>
        </ChildContent>
        
        <EmptyContent>
            <EmptyDataGridContent Mensaje="No hay Indicadores en esta area"/>
        </EmptyContent>
       
    </FluentDataGrid>
    
    <div style="flex-shrink: 0; padding-top: 10px;">
        <FluentPaginator State="@paginationState"/>
    </div>
}

@code {
    [Parameter] public List<IndicadorDeAreaDto> Areas { get; set; } = new();
    [Parameter] public bool IndicadorEsPorcentual { get; set; }
    private string nameFilter = string.Empty;
    private string? evaluacionFilter;
    private List<SelectOption<string?>> evaluacionOptions = new();
    private string? tipoFilter;
    private List<SelectOption<string?>> tipoOptions = new();

    
    private PaginationState paginationState = new() { ItemsPerPage = 10 };

    protected override void OnInitialized()
    {
        base.OnInitialized();
        evaluacionOptions = Areas
            .Select(i => i.Evaluacion!)
            .Distinct()
            .OrderBy(e => e)
            .Select(e => new SelectOption<string?> 
            { 
                Value = e.GetDisplayName(), 
                Text = e.GetDisplayName() 
            })
            .ToList();

    tipoOptions = Enum.GetValues<AreaTipo>()
    .Select(t => new SelectOption<string?>
    {
    Value = t.ToString(),
    Text = t.GetDisplayName()
    })
    .ToList();
    }

    private IEnumerable<IndicadorDeAreaDto> FilteredItems =>
        Areas.Where(i =>
            (string.IsNullOrEmpty(nameFilter) || i.AreaNombre.Contains(nameFilter, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrEmpty(evaluacionFilter) || i.Evaluacion.GetDisplayName() == evaluacionFilter) &&
            (string.IsNullOrEmpty(tipoFilter) || i.Tipo.ToString() == tipoFilter));


    private async Task ClearTipoFilter()
    {
        tipoFilter = null;
        await ResetPagination();
    }
    
    private async Task ResetPagination()
    {
        await paginationState.SetCurrentPageIndexAsync(0);
    }
    private async Task ClearEvaluacionFilter()
    {
        evaluacionFilter = null;
        await ResetPagination();
    }
}