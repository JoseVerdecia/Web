@page "/resumen-evaluacion-procesos"
@attribute [Authorize(Roles = AppRoles.Administrador)]
@using Microsoft.AspNetCore.Authorization
@using WEB.Core.Extensions
@using WEB.Core.Mediator
@using WEB.Core.Services
@using WEB.Services
@using WEB.Data
@rendermode InteractiveServer
@inject IMediator Mediator
@inject IJSRuntime JSRuntime
@inject ExcelExportService ExportService
@inject ExportPdfService ExportPdfService
@inject NavigationManager NavigationManager



<FluentLayout>
    <FluentGrid Spacing="4">
        <FluentGridItem xs="12">
            <FluentStack HorizontalAlignment="HorizontalAlignment.SpaceBetween">
                <Title Icono="@(new Icons.Regular.Size24.AppsList())" ValueTitle="Resumen"></Title>
                <FluentStack Width="fit-content" HorizontalAlignment="HorizontalAlignment.End">
                    <FluentMenuButton IconStart="@(new Icons.Regular.Size20.ArrowDownload())" Text="Exportar">
                        <FluentMenuItem OnClick="@(() => ExportToExcel())">Excel</FluentMenuItem>
                        <FluentMenuItem OnClick="@(() => ExportToPdf())">PDF</FluentMenuItem>
                    </FluentMenuButton>
                    <FluentButton Appearance="Appearance.Accent"
                                  OnClick="@(() => NavigationManager.NavigateTo("/proceso"))"
                                  IconStart="@(new Icons.Regular.Size20.ArrowLeft())">
                        Volver
                    </FluentButton>
                </FluentStack>
            </FluentStack>
        </FluentGridItem>

        <FluentGridItem xs="12">
            @if (isLoading)
            {
                <FluentProgressRing />
            }
            else if (!datosProcesos.Any())
            {
                <FluentLabel>No hay procesos registrados.</FluentLabel>
            }
            else
            {
                <div style="overflow-x: auto;">
                    <table class="resumen-table">
                        <thead>
                            <tr>
                                <th rowspan="2">PROCESOS</th>
                                <th rowspan="2">CATEGORÍA</th>
                                <th rowspan="2">TOTAL</th>
                                <th colspan="2">SOBRE-CUMPLIDOS</th>
                                <th colspan="2">CUMPLIDOS</th>
                                <th colspan="2">SC+C</th>
                                <th colspan="2">PARCIALMENTE CUMPLIDO</th>
                                <th colspan="2">SC+C+PC</th>
                                <th colspan="2">INCUMPLIDOS</th>
                                <th rowspan="2">NO EVALUADOS</th>
                                <th rowspan="2">EVALUACIÓN DEL PROCESO</th>
                            </tr>
                            <tr>
                                <th>TOTAL</th><th>%</th>
                                <th>TOTAL</th><th>%</th>
                                <th>TOTAL</th><th>%</th>
                                <th>TOTAL</th><th>%</th>
                                <th>TOTAL</th><th>%</th>
                                <th>TOTAL</th><th>%</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var proceso in datosProcesos)
                            {
                                var filasProceso = proceso.Filas;
                                var primeraFila = true;
                                foreach (var fila in filasProceso)
                                {
                                    <tr @key="@($"{proceso.NombreProceso}-{fila.Nombre}")" class="@(fila.Nombre == "Indicadores esenciales" ? "fila-esencial" : "")">
                                        @if (primeraFila)
                                        {
                                            <td class="celda-proceso" rowspan="@filasProceso.Count">
                                                @proceso.NombreProceso
                                            </td>
                                            primeraFila = false;
                                        }
                                        <td>@fila.Nombre</td>
                                        <td class="celda-numero">@fila.Total</td>
                                        <td class="celda-numero">@fila.Sobrecumplidos</td>
                                        <td class="celda-numero">@FormatearPorcentaje(fila.PorcentajeS)</td>
                                        <td class="celda-numero">@fila.Cumplidos</td>
                                        <td class="celda-numero">@FormatearPorcentaje(fila.PorcentajeC)</td>
                                        <td class="celda-numero">@fila.SCplusC</td>
                                        <td class="celda-numero">@FormatearPorcentaje(fila.PorcentajeSCplusC)</td>
                                        <td class="celda-numero">@fila.ParcialmenteCumplidos</td>
                                        <td class="celda-numero">@FormatearPorcentaje(fila.PorcentajePC)</td>
                                        <td class="celda-numero">@fila.SCplusCplusPC</td>
                                        <td class="celda-numero">@FormatearPorcentaje(fila.PorcentajeSCplusCplusPC)</td>
                                        <td class="celda-numero">@fila.Incumplidos</td>
                                        <td class="celda-numero">@FormatearPorcentaje(fila.PorcentajeI)</td>
                                        <td class="celda-numero">@fila.NoEvaluados</td>
                                        @if (filasProceso.Count > 1 && Array.IndexOf(filasProceso.ToArray(), fila) == 0)
                                        {
                                            <td class="celda-evaluacion" rowspan="@filasProceso.Count">
                                                @proceso.EvaluacionProceso.GetDisplayName()
                                            </td>
                                        }
                                        else if (filasProceso.Count == 1)
                                        {
                                            <td class="celda-evaluacion">
                                                @proceso.EvaluacionProceso.GetDisplayName()
                                            </td>
                                        }
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }
        </FluentGridItem>
    </FluentGrid>
</FluentLayout>

