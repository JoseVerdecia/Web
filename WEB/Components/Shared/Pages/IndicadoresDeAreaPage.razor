@page "/indicadores/{Id:int}/areas"
@attribute [Authorize(Roles = AppRoles.Administrador)]
@using Microsoft.AspNetCore.Authorization
@using WEB.Components.Shared
@using WEB.Data
@rendermode InteractiveServer
@inject NavigationManager Navigation




<FluentGridItem Justify="JustifyContent.FlexEnd" xs="12">
    <FluentButton Appearance="Appearance.Accent"
                  IconStart="@(new Icons.Regular.Size20.ArrowLeft())"
                  OnClick="@(() => Navigation.NavigateTo("/indicadores"))">
        Volver
    </FluentButton>
</FluentGridItem>

<IndicadoresDeAreaContent Id="@Id" />

@code{
    [Parameter]
    public int Id { get; set; }
}