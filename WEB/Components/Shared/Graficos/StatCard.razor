<FluentCard Style="padding: 16px; background: var(--neutral-layer-2); text-align: center; height: 100%;">
    <FluentLabel Typo="Typography.H3" Color="@Color">@Value</FluentLabel>
    <FluentLabel Typo="Typography.Body" Style="color: var(--neutral-foreground-hint);">@Label</FluentLabel>
</FluentCard>

@code {
    [Parameter] public string Value { get; set; } = "0";
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public Color Color { get; set; } = Color.Accent;
}