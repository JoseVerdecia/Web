<FluentButton 
              Color="@(Outlined ? "var(--success)" : "#ffffff")"
              Disabled="@Disable"
              BackgroundColor="@(Outlined ? "transparent" : "var(--success)")"
              Style="@(Outlined ? $"border: 1px solid var(--success); padding-right: 10px;width:{Width};height:{Heigth};" : $"padding-right: 10px;width:{Width};height:{Heigth};")"
              IconStart="@IconStart"
              StopPropagation="true"
              OnClick="@OnClick">
    @Text
</FluentButton>

@code {
    [Parameter] public string? Text { get; set; }
    [Parameter] public string? Width { get; set; }
    [Parameter] public string? Heigth { get; set; }
    [Parameter] public bool Disable { get; set; } 
    [Parameter] public bool Outlined { get; set; } 
    [Parameter] public EventCallback<MouseEventArgs> OnClick { get; set; }
    [Parameter] public Icon? IconStart { get; set; }
}