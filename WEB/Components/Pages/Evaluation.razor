@page "/evaluacion/programar"
@using System.Globalization
@using Microsoft.AspNetCore.Authorization
@using WEB.Components.Shared
@rendermode InteractiveServer
@using WEB.Data
@attribute [Authorize(Roles = AppRoles.Administrador)]

<PageTitle>Programar Evaluación Global</PageTitle>

<div style="max-width: 1100px; margin: 0 auto; padding: 16px;">
  
    <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" Style="width: 100%;">
        <Title ValueTitle="Cierre de Evaluación" Icono="@(new Icons.Regular.Size24.CalendarClock())"></Title>
    </FluentStack>

    <FluentDivider Style="margin: 1rem 0;" />
    <FluentGrid Spacing="4">

       
        <FluentGridItem xs="12" HiddenWhen="GridItemHidden.SmAndUp">
            <FluentLabel Typo="Typography.Body" Style="line-height: 1.5; margin-bottom: 1.5rem;">
                Programa cuándo se ejecutará la evaluación automática. 
            </FluentLabel>
        </FluentGridItem>
        
        <FluentGridItem xs="12" HiddenWhen="GridItemHidden.Xs">
            <FluentLabel Typo="Typography.Body" Style="line-height: 1.6; margin-bottom: 1.5rem;">
                Programa la fecha y hora exacta en que se ejecutará la evaluación automática de todos los 
                <strong>procesos</strong> y <strong>objetivos</strong> del sistema.
            </FluentLabel>
        </FluentGridItem>

      
        <FluentGridItem xs="12" md="7" lg="6">
            <FluentCard Style="padding: 16px; background: var(--neutral-layer-2);">
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
                    <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">
                        <FluentIcon Value="@(new Icons.Regular.Size16.Calendar())" Style="margin-right: 6px;" />
                        Fecha de ejecución
                    </FluentLabel>
                    <FluentCalendar Culture="CultureInfo.CurrentCulture" 
                                   @bind-Value="@FechaSeleccionada"
                                   DisabledDateFunc="@FechaPasada"
                                   Style="width: 100%;" />
                </FluentStack>
            </FluentCard>
        </FluentGridItem>
        
        <FluentGridItem xs="12" md="5" lg="6">
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="16">
                <FluentCard Style="padding: 16px; background: var(--neutral-layer-2);">
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
                        <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">
                            <FluentIcon Value="@(new Icons.Regular.Size16.Clock())" Style="margin-right: 6px;" />
                            Hora de ejecución
                        </FluentLabel>
                        <FluentTimePicker @bind-Value="@HoraSeleccionada"
                                         TimeDisplay="TimeDisplay.HourMinute"
                                         Style="width: 100%;" />
                    </FluentStack>
                </FluentCard>
                
              
                
                <FluentButton 
                    Style="width: 100%;height: 48px;"
                    Appearance="Appearance.Accent"
                    Disabled="@(!FechaSeleccionada.HasValue || Programando)"
                    OnClick="@ProgramarJobAsync">
                    Programar
                </FluentButton>
           
                
                @if (FechaSeleccionada.HasValue && HoraSeleccionada.HasValue)
        {
            var fechaCompleta = new DateTime(
                FechaSeleccionada.Value.Year, 
                FechaSeleccionada.Value.Month, 
                FechaSeleccionada.Value.Day,
                HoraSeleccionada.Value.Hour, 
                HoraSeleccionada.Value.Minute, 0);

            if (fechaCompleta > DateTime.Now)
            {
                <FluentGridItem xs="12" HiddenWhen="GridItemHidden.Xs">
                    <FluentMessageBar Intent="MessageIntent.Info" Style="margin-top: 16px;">
                        <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">
                                Fecha de evaluación programada: 
                            </FluentLabel>
                            <FluentLabel Typo="Typography.Body" Style="text-transform: capitalize;">
                                @fechaCompleta.ToString("dddd, dd 'de' MMMM 'de' yyyy 'a las' HH:mm", CultureInfo.CurrentCulture)
                            </FluentLabel>
                        </FluentStack>
                    </FluentMessageBar>
                </FluentGridItem>
            }
            else
            {
                <FluentGridItem xs="12">
                    <FluentMessageBar Intent="MessageIntent.Error" Style="margin-top: 16px;">
                        La fecha y hora seleccionadas ya pasaron. Por favor, selecciona una fecha futura.
                    </FluentMessageBar>
                </FluentGridItem>
            }
        }
            </FluentStack>
        </FluentGridItem>
        
        
        
        @if (!string.IsNullOrEmpty(Mensaje))
        {
            <FluentGridItem xs="12">
                <FluentMessageBar Intent="@(EsError ? MessageIntent.Error : MessageIntent.Success)" Style="margin-top: 16px;">
                    @Mensaje
                </FluentMessageBar>
            </FluentGridItem>
        }
        
        @if (JobIdProgramado != null)
        {
            <FluentGridItem xs="12">
                <FluentCard Style="padding: 12px 16px; background: var(--neutral-layer-1); border-left: 4px solid var(--success); margin-top: 16px;">
                    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="12" VerticalAlignment="VerticalAlignment.Center">
                        <FluentBadge Appearance="Appearance.Neutral" Color="Color.Success">✓ Programado</FluentBadge>
                        <FluentLabel Typo="Typography.Body" Style="color: var(--neutral-foreground-hint);">
                            ID de trabajo: 
                            <span style="font-family: monospace; color: var(--neutral-foreground); font-size: 14px;">@JobIdProgramado</span>
                        </FluentLabel>
                        <FluentAnchor Href="/hangfire" Appearance="Appearance.Hypertext" Style="margin-left: auto;">
                            Ver en Panel de Monitoreo →
                        </FluentAnchor>
                    </FluentStack>
                </FluentCard>
            </FluentGridItem>
        }
        
        <FluentGridItem xs="12" HiddenWhen="GridItemHidden.Xs">
            <FluentMessageBar Intent="MessageIntent.Warning" Style="margin-bottom: 20px; margin-top: 16px;">
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                    <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">
                        Reglas de esta evaluación
                    </FluentLabel>
                    <FluentLabel Typo="Typography.Body">
                        Se clasificarán automáticamente como <em>Incumplido</em>:
                    </FluentLabel>
                    <ul style="margin: 4px 0 0 0; padding-left: 20px;">
                        <li>Los procesos y objetivos que no tengan indicadores asociados.</li>
                        <li>Los indicadores que no tengan una meta real asignada.</li>
                        <li>Los indicadores que se encuentren en estado "No Evaluado".</li>
                    </ul>
                    <FluentLabel Typo="Typography.Body">
                        Para ver si la evaluación ha terminado, consulta el
                        <FluentAnchor Href="/hangfire" Appearance="Appearance.Hypertext">Panel de Monitoreo</FluentAnchor>.
                    </FluentLabel>
                </FluentStack>
            </FluentMessageBar>
        </FluentGridItem>
        
        <FluentGridItem xs="12" HiddenWhen="GridItemHidden.SmAndUp">
            <FluentMessageBar Intent="MessageIntent.Warning" Style="margin-bottom: 20px; margin-top: 16px;">
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="6">
                    <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">
                        ⚠️ Reglas
                    </FluentLabel>
                    <FluentLabel Typo="Typography.Body">
                        Sin indicadores, sin meta o "No evaluado" = <strong>Incumplido</strong>
                    </FluentLabel>
                    <FluentAnchor Href="/hangfire" Appearance="Appearance.Hypertext">
                        Ver Panel de Monitoreo →
                    </FluentAnchor>
                </FluentStack>
            </FluentMessageBar>
        </FluentGridItem>

    </FluentGrid>
</div>