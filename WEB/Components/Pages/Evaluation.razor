@page "/evaluacion/programar-periodo"
@using System.Globalization
@using Hangfire
@using Microsoft.AspNetCore.Authorization
@using WEB.Components.Shared
@using WEB.Core.Services
@rendermode InteractiveServer
@using WEB.Data
@attribute [Authorize(Roles = AppRoles.Administrador)]
@inject IBackgroundJobClient BackgroundJobClient
@inject EvaluationPeriodService EvaluationPeriod
@implements IDisposable


<FluentStack HorizontalAlignment="HorizontalAlignment.Start">
    <Title ValueTitle="Periodo de Evaluación" Icono="@(new Icons.Regular.Size24.CalendarClock())" />
</FluentStack>

<div style="max-width: 800px; margin: 0 auto; padding: 16px;">
    <FluentDivider style="margin-top:10px;"/>

    <FluentStack Orientation="Orientation.Vertical" VerticalGap="16">
       
        <FluentCard Style="margin-top:10px;padding: 16px;">
            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">
                Estado actual:
                <span style="color: @(EvaluationPeriod.IsActive ? "green" : "red")">
                    @(EvaluationPeriod.IsActive ? "EVALUACIÓN EN CURSO" : "Evaluación inactiva")
                </span>
            </FluentLabel>
        </FluentCard>

        <div class="calendarios-container">
            <FluentCard Style="padding: 16px;" Class="calendario-card">
                <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">
                    <FluentIcon Value="@(new Icons.Regular.Size16.Play())" /> Inicio de la evaluación
                </FluentLabel>
                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="12">
                    <FluentCalendar @bind-Value="@FechaInicio" DisabledDateFunc="@FechaPasada" />
                    <FluentTimePicker @bind-Value="@HoraInicio" />
                </FluentStack>
            </FluentCard>

            <FluentCard Style="padding: 16px;" Class="calendario-card">
                <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">
                    <FluentIcon Value="@(new Icons.Regular.Size16.Stop())" /> Fin de la evaluación
                </FluentLabel>
                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="12">
                    <FluentCalendar @bind-Value="@FechaFin" DisabledDateFunc="@FechaPasada" />
                    <FluentTimePicker @bind-Value="@HoraFin" />
                </FluentStack>
            </FluentCard>
        </div>

        <FluentButton Appearance="Appearance.Accent" 
                       OnClick="@ProgramarPeriodoAsync" 
                       Disabled="@(Programando || !EsPeriodoValido())">
            Programar periodo
        </FluentButton>

        @if (!string.IsNullOrEmpty(Mensaje))
        {
            <FluentMessageBar Intent="@(EsError ? MessageIntent.Error : MessageIntent.Success)">
                @Mensaje
            </FluentMessageBar>
        }

        @if (JobIdInicio != null && JobIdFin != null)
        {
            <FluentCard Style="padding: 12px; border-left: 4px solid var(--success);">
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                    <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Trabajos programados</FluentLabel>
                    <FluentLabel>Inicio: @FechaInicioCombinada?.ToString("g") (ID: @JobIdInicio)</FluentLabel>
                    <FluentLabel>Fin: @FechaFinCombinada?.ToString("g") (ID: @JobIdFin)</FluentLabel>
                </FluentStack>
            </FluentCard>
        }
    </FluentStack>
</div>

<style>
    .calendarios-container {
        display: flex;
        gap: 16px;
    }

    .calendario-card {
        flex: 1;
    }

    @@media (max-width: 959px) {
        .calendarios-container {
            flex-direction: column;
        }
    }
</style>