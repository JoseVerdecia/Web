@page "/indicadores"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.FluentUI.AspNetCore.Components.Icons.Filled
@using WEB.Components.Administrador.Indicador
@using WEB.Components.Shared
@using WEB.Core.Mediator
@inject IDialogService DialogService
@inject IMediator Mediator
@attribute [Authorize]
@rendermode  InteractiveServer


@if (!string.IsNullOrEmpty(errorMessage))
{
    <FluentMessageBar Title="Error" Intent="MessageIntent.Error" AllowDismiss="true">
        @errorMessage
    </FluentMessageBar>
}


<FluentLayout>
    <div class="page-container" style="height: calc(100vh - 120px); display: flex; flex-direction: column;">
        
        <div class="page-header" style="margin-bottom: 16px; flex-shrink: 0;">
            <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween">
            <Title Icono="@(new Size24.ArrowTrendingLines())" ValueTitle="Indicadores"></Title>
            
            <FluentStack Width="inline-block" HorizontalAlignment="HorizontalAlignment.End">
                @if (ActiveTabId == "tab-activos")
                {
                   
                        
                        <FluentButton   OnClick="EliminarSeleccionados"
                                        Appearance="Appearance.Outline"
                                        Disabled="@(indicadorDataGrid == null || !indicadorDataGrid.HasSelection)"
                                        IconStart="@(new Icons.Regular.Size16.Delete())">
                            Eliminar
                        </FluentButton>
                        
                        <FluentButton   OnClick="@OpenCreateWizardDialog"
                                        Appearance="Appearance.Accent"
                                        IconStart="@(new Icons.Regular.Size20.AddSquare())">
                            Crear Inicador
                        </FluentButton>
                   
                    
                }
                else
                {
                    <FluentButton  OnClick="@RestoreSelectedIndicadores"
                                   Disabled="@(deletedDataGrid == null || !deletedDataGrid.HasSelection)"
                                   IconStart="@(new Icons.Regular.Size20.ArrowSync().WithColor(Color.Accent))">
                        Restaurar
                    </FluentButton>
                    
                    <FluentButton 
                                  OnClick="@DeleteSelectedPermanently"
                                  Disabled="@(selectedDeletedIds.Count == 0)"
                                  IconStart="@(new Icons.Regular.Size16.Delete().WithColor(Color.Error))">
                        Eliminar
                    </FluentButton>
                }
            </FluentStack>
            </FluentStack>
        </div>
        
        <FluentDivider Style="margin: 1rem 0;" />
        
        <FluentTabs Width="100%" @bind-ActiveTabId="@ActiveTabId" OnTabChange="HandleTabChange">
            <FluentTab Id="tab-activos" Label="Indicadores activos">
                @if (isLoading)
                {
                    <FluentStack HorizontalAlignment="HorizontalAlignment.Center" Style="padding: 40px;">
                        <FluentProgressRing />
                    </FluentStack>
                }
                else
                {
                    <FluentSplitter Orientation="Orientation.Horizontal"
                                    Panel1Size="60%"
                                    Panel2Size="40%"
                                    Panel1MinSize="400px"
                                    Panel2MinSize="250px"
                                    Collapsed="@(selectedIndicador == null)"
                                    BarSize="4">
                        <Panel1>
                            <div style="height: 100%; overflow-x:auto;width:100%;display: flex; flex-direction: column;  min-height: 0;">
                                <IndicadorDataGrid
                                    @ref="indicadorDataGrid"
                                    Items="gridItems"
                                    OnEdit="OpenEditDialog"
                                    OnDelete="DeleteIndicador"
                                    OnViewDetails="ViewIndicadorDetails"
                                    OnRowSelected="HandleRowSelected"
                                    SelectionChanged="OnGridSelectionChanged" />
                            </div>
                        </Panel1>
                        <Panel2>
                            <div style="height: 100%; display: flex; flex-direction: column; background: var(--neutral-layer-1);">
                                @if (selectedIndicador != null)
                                {
                                    <header style="display: flex; justify-content: space-between; align-items: center; padding: 12px 16px; border-bottom: 1px solid var(--neutral-stroke); flex-shrink: 0;">
                                        <FluentButton Appearance="Appearance.Stealth"
                                                      IconStart="@(new Icons.Regular.Size16.Dismiss())"
                                                      OnClick="() => selectedIndicador = null"
                                                      Title="Cerrar panel" />
                                    </header>
                                    <div style="flex: 1; overflow: auto; padding: 16px;">
                                        <IndicadorDeAreaDetailGrid Areas="selectedIndicador.Areas" />
                                    </div>
                                }
                                else
                                {
                                    <div style="display: flex; align-items: center; justify-content: center; height: 100%; color: var(--neutral-foreground-hint);">
                                        <FluentLabel>Seleccione un indicador para ver sus áreas</FluentLabel>
                                    </div>
                                }
                            </div>
                        </Panel2>
                    </FluentSplitter>
                }
            </FluentTab>

            <FluentTab Id="tab-papelera" Label="Papelera">
                @if (isLoadingPapelera)
                {
                    <FluentStack HorizontalAlignment="HorizontalAlignment.Center" Style="padding: 40px;">
                        <FluentProgressRing />
                    </FluentStack>
                }
                else
                {
                    <div style="overflow-x: auto; width: 100%;">
                    <IndicadorDeletedDataGrid @ref="deletedDataGrid"
                                              Items="deletedGridItems"
                                              OnRestore="RestoreSingleIndicador"
                                              OnDeletePermanently="DeletePermanently"
                                              SelectionChanged="OnDeletedGridSelectionChanged" />
                    </div>
                }
            </FluentTab>
        </FluentTabs>
    </div>
</FluentLayout>