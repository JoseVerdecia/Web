@page "/indicadores"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.FluentUI.AspNetCore.Components.Icons.Filled
@using WEB.Components.Administrador.Indicador
@using WEB.Components.Shared
@using WEB.Core.Mediator
@using WEB.Data
@using WEB.Services
@attribute [Authorize(Roles=AppRoles.Administrador)]
@inject IDialogService DialogService
@inject NavigationManager NavigationManager
@inject IMediator Mediator
@attribute [Authorize]
@inject ExcelExportService ExcelExportService
@inject IJSRuntime JSRuntime
@rendermode  InteractiveServer

<PageTitle>Indicador</PageTitle>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <FluentMessageBar Title="Error" Intent="MessageIntent.Error" AllowDismiss="true">
        @errorMessage
    </FluentMessageBar>
}

<FluentLayout>
  
    <FluentGrid Spacing="4" Style="width: 100%;">
        <FluentGridItem xs="12">
            <FluentGrid Justify="JustifyContent.SpaceBetween" AlignItems="Alignment.Center" Spacing="3">
                
                
                <FluentGridItem xs="12" md="6">
                    <Title Icono="@(new Size24.ArrowTrendingLines())" ValueTitle="Indicadores"></Title>
                </FluentGridItem>

             
                <FluentGridItem xs="12" md="6" Justify="JustifyContent.FlexEnd">
               
                    <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.End" Gap="8" Style="flex-wrap: wrap;">
                        @if (ActiveTabId == "tab-activos")
                        {
                            <FluentMenuButton Text="Exportar">
                                <FluentMenuItem Disabled="@(!gridItems.Any())" OnClick="ExportIndicadores"> Excel</FluentMenuItem>
                                <FluentMenuItem Disabled="@(!gridItems.Any())" OnClick="ExportIndicadoresPdf"> PDF</FluentMenuItem>
                            </FluentMenuButton>
                            
                            <FluentButton   
                                OnClick="EliminarSeleccionados"
                                Appearance="Appearance.Outline"
                                Disabled="@(indicadorDataGrid == null || !indicadorDataGrid.HasSelection)"
                                IconStart="@(new Icons.Regular.Size16.Delete())">
                                Eliminar
                            </FluentButton>
                            
                            <FluentButton OnClick="@(() => NavigationManager.NavigateTo("/indicadores/form"))"
                                          Appearance="Appearance.Accent"
                                          IconStart="@(new Icons.Regular.Size20.AddSquare())">
                                Crear
                            </FluentButton>
                        }
                        else
                        {
                            <FluentButton  
                                OnClick="@RestoreSelectedIndicadores"
                                Disabled="@(deletedDataGrid == null || !deletedDataGrid.HasSelection)"
                                IconStart="@(new Icons.Regular.Size20.ArrowSync().WithColor(Color.Accent))">
                                Restaurar
                            </FluentButton>
                            
                            <FluentButton 
                                OnClick="@DeleteSelectedPermanently"
                                Disabled="@(selectedDeletedIds.Count == 0)"
                                IconStart="@(new Icons.Regular.Size16.Delete().WithColor(Color.Error))">
                                Eliminar
                            </FluentButton>
                        }
                    </FluentStack>
                </FluentGridItem>
            </FluentGrid>
        </FluentGridItem>

        <!-- Separador -->
        <FluentGridItem xs="12">
            <FluentDivider Style="margin: 0.5rem 0;" />
        </FluentGridItem>
        
        <FluentGridItem xs="12">
            <FluentTabs Height="200px" Width="100%" @bind-ActiveTabId="@ActiveTabId" OnTabChange="HandleTabChange">
                <FluentTab Id="tab-activos" Label="Activos">
                    @if (isLoading)
                    {
                        <FluentStack HorizontalAlignment="HorizontalAlignment.Center" Style="padding: 40px;">
                            <FluentProgressRing />
                        </FluentStack>
                    }
                    else
                    {
                                <div style="height: fit-content; overflow-x:auto;width:100%;display: flex; flex-direction: column;  min-height: 0;">
                                    <IndicadorDataGrid
                                        @ref="indicadorDataGrid"
                                        AreasBaseUrl="/indicadores"
                                        EditBaseUrl="/indicadores/jefeProcesoform"
                                        Items="gridItems"
                                        OnDelete="DeleteIndicador"
                                        OnViewDetails="ViewIndicadorDetails"
                                        OnRowSelected="HandleRowSelected"
                                        SelectionChanged="OnGridSelectionChanged" />
                                </div>
                    }
                </FluentTab>

                <FluentTab Id="tab-papelera" Label="Papelera">
                    @if (isLoadingPapelera)
                    {
                        <FluentStack HorizontalAlignment="HorizontalAlignment.Center" Style="padding: 40px;">
                            <FluentProgressRing />
                        </FluentStack>
                    }
                    else
                    {
                        <div style="overflow-x: auto; width: 100%;">
                            <IndicadorDeletedDataGrid @ref="deletedDataGrid"
                                                      Items="deletedGridItems"
                                                      OnRestore="RestoreSingleIndicador"
                                                      OnDeletePermanently="DeletePermanently"
                                                      SelectionChanged="OnDeletedGridSelectionChanged" />
                        </div>
                    }
                </FluentTab>
            </FluentTabs>
        </FluentGridItem>
    </FluentGrid>
</FluentLayout>